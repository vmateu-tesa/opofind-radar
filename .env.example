# Copia este fichero a .env y rellena los valores reales. NUNCA subas .env a git.

# --- Modo de ejecución ---
# true = no envía nada de verdad, solo loguea lo que enviaría. Empieza aquí.
DRY_RUN=true

# --- Base de datos ---
DB_PATH=data/oporadar.db

# --- Telegram (canal principal recomendado) ---
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- WhatsApp Cloud API (canal secundario, opcional) ---
WHATSAPP_ENABLED=false
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TO_NUMBER=
WHATSAPP_TEMPLATE_NAME=opo_alerta

# --- Scheduler (solo si se ejecuta como proceso persistente, no en cron externo) ---
CRON_HOUR=8
CRON_MINUTE=0
TZ=Europe/Madrid

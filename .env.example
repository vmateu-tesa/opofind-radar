# Copia este fichero a .env y rellena los valores reales. NUNCA subas .env a git.

# --- Telegram (canal principal recomendado) ---
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
ENABLE_TELEGRAM=1

# --- WhatsApp Cloud API (canal secundario, opcional) ---
ENABLE_WHATSAPP=0
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_TO_NUMBER=

# --- Email (canal opcional; con Gmail usa una "contraseña de aplicacion") ---
ENABLE_EMAIL=0
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# --- Modulo de estudio (Gemini, opcional -- si se deja vacio, esas funciones
# del frontend devuelven "No LLM API Key configured" en vez de fallar) ---
GEMINI_API_KEY=
# LLM_API_KEY tambien funciona como alias si ya lo tenias configurado asi.

# --- Avisos de plazo ---
# Dias de antelacion para recordar el cierre de un plazo (apertura siempre
# se avisa). '5,1' = avisa cuando quedan 5 dias y de nuevo cuando queda 1.
DIAS_AVISO_CIERRE=5,1

# --- Ventanas de raspado (dias hacia atras) ---
BOE_DIAS_ATRAS=30
DOGV_DIAS_ATRAS=7
BOP_DIAS_ATRAS=3

# --- Scheduler ---
# 0 (o vacio) = cron diario fijo a las 4:00. Un numero > 0 = comprobar cada
# INTERVAL_HOURS horas en vez de una vez al dia.
INTERVAL_HOURS=0
